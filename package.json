{
  "name": "meeting-ai-app",
  "version": "1.0.0",
  "description": "AI Meeting & Content Assistant Desktop Application",
  "main": "electron/main.js",
  "author": "MeetingAI Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/AshinTomMathew/meeting-ai-app"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@xenova/transformers": "^2.17.2",
    "bcryptjs": "^2.4.3",
    "docx": "^9.5.1",
    "dotenv": "^16.3.1",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "google-auth-library": "^10.5.0",
    "jspdf": "^4.0.0",
    "mermaid": "^11.12.2",
    "mysql2": "^3.16.0",
    "node-fetch": "^3.3.2",
    "onnxruntime-node": "^1.23.2",
    "pdfkit": "^0.13.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0",
    "wavefile": "^11.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "vite": "^5.0.8",
    "wait-on": "^7.2.0"
  },
  "build": {
    "npmRebuild": false,
    "appId": "com.meetingai.app",
    "productName": "MeetingAI",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*",
      "package.json",
      ".env"
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**/*",
      "**/node_modules/ffprobe-static/**/*",
      "**/node_modules/@xenova/**/*",
      "**/node_modules/onnxruntime-node/**/*"
    ],
    "win": {
      "target": "portable",
      "icon": "public/icon.png"
    },
    "extraResources": [
      {
        "from": "backend/dist/main.exe",
        "to": "bin/main.exe"
      }
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "public/icon.png"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "public/icon.png"
    }
  }
}
